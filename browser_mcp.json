{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "airbnb": {
      "command": "npx",
      "args": [
        "-y",
        "@openbnb/mcp-server-airbnb"
      ]
    },
     "ddg-search": {
            "command": "uvx",
            "args": ["duckduckgo-mcp-server"]
        },
      "enuygun": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.enuygun.com/mcp"
      ]
    }
  }
}